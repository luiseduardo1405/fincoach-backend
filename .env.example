DATABASE_URL=postgres://user:password@host:port/defaultdb?sslmode=require
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_random
GROQ_API_KEY=gsk_tu_api_key_de_groq
PORT=3000
NODE_ENV=development

# ── Mercado Pago (suscripciones). Opcionales: sin ellos las rutas de
# /subscriptions responden 503 y el resto del backend funciona normal. ──
MP_ACCESS_TOKEN_TEST=TEST-xxxxxxxxxxxxxxxxxxxx
MP_ACCESS_TOKEN_PROD=APP_USR-xxxxxxxxxxxxxxxxxxxx
# Secreto que TÚ defines; regístralo en la URL del webhook como
# https://.../webhooks/mercadopago?secret=ESTE_VALOR
MP_WEBHOOK_SECRET=define_un_secreto_largo_y_random

# IDs de los 4 preapproval_plan creados en MP (Fase 0). Solo los usa
# `npm run db:seed-plans` para sembrar el catálogo.
MP_PLAN_ID_PRO_MONTHLY=
MP_PLAN_ID_PRO_ANNUAL=
MP_PLAN_ID_MAX_MONTHLY=
MP_PLAN_ID_MAX_ANNUAL=

# ── Anthropic (consejo semanal de Lucas, plan Max). Opcional: sin esta
# clave el cron no arranca. ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
